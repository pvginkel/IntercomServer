<local:BaseWindow x:Class="IntercomTest.MainWindow"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:local="clr-namespace:IntercomTest"
                  ShowInTaskbar="True"
                  mc:Ignorable="d"
                  Title="MainWindow" Height="500" Width="700"
                  Closed="BaseWindow_Closed"
                  Loaded="BaseWindow_Loaded"
                  Icon="/mainicon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ToolBar>
            <Button x:Name="_addDevice" Content="Add Device" Click="_addDevice_Click" />
            <Button x:Name="_doorbell" Content="Doorbell" Click="_doorbell_Click" />
            <CheckBox x:Name="_autoAccept" Content="Auto Accept" Checked="_autoAccept_Checked" Unchecked="_autoAccept_Checked"/>
            <Button x:Name="_aecTest" Content="AEC Test" Click="_aecTest_Click" />
        </ToolBar>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="1">
            <StackPanel Orientation="Vertical">
                <StackPanel x:Name="_testDevices" Orientation="Vertical" />
                <StackPanel x:Name="_devices" Orientation="Vertical" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</local:BaseWindow>
